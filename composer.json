{
    "name": "opencart/qa-testing",
    "description": "QA Testing Suite para OpenCart - Pruebas Unitarias",
    "license": "GPL-3.0",
    "authors": [
        {
            "name": "QA Team",
            "email": "qa@opencart.local"
        }
    ],
    "require": {
        "php": ">=8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "phpunit/php-code-coverage": "^10.1"
    },
    "autoload": {
        "psr-4": {
            "Opencart\\": "opencart/",
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit --no-coverage",
        "test:coverage": "phpunit --no-coverage",
        "test:unit": "phpunit tests/unitarias --no-coverage"
    }
}
